// Simulasi Harga Sultan
Route::get('/test-harga', function () {
    $potongan = ['khfy' => 1000, 'adam' => 500, 'kaje' => 2000, 'digiflazz' => 0];
    $produkKhfy = \Illuminate\Support\Facades\DB::table('layanan_khfy')->where('status', 'active')->first();
    $produkAdam = \Illuminate\Support\Facades\DB::table('ppob_products')->where('is_active', 1)->first();
    $produkKaje = \Illuminate\Support\Facades\DB::table('layanan_kaje')->where('status', 'active')->first();
    $hitungHarga = function ($hargaAsli, $provider, $level) use ($potongan) { return ($level === 'reseller') ? max($hargaAsli - ($potongan[$provider] ?? 0), 0) : $hargaAsli; };
    return response()->json([
        'SIMULASI_USER_BIASA' => ['khfy' => $hitungHarga($produkKhfy->harga_jual ?? 0, 'khfy', 'user'), 'adam' => $hitungHarga($produkAdam->price_sell ?? 0, 'adam', 'user'), 'kaje' => $hitungHarga($produkKaje->harga_jual ?? 0, 'kaje', 'user')],
        'SIMULASI_RESELLER' => ['khfy' => $hitungHarga($produkKhfy->harga_jual ?? 0, 'khfy', 'reseller'), 'adam' => $hitungHarga($produkAdam->price_sell ?? 0, 'adam', 'reseller'), 'kaje' => $hitungHarga($produkKaje->harga_jual ?? 0, 'kaje', 'reseller')]
    ]);
});
