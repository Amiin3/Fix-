    // Statistik Member
    Route::get('/statistik', function () {
        $auth = auth()->user(); $db = \Illuminate\Support\Facades\DB::class;
        $total_in = $db::table('deposits')->where('user_id', $auth->id)->whereIn('status', ['success', 'sukses', 'paid', 'Success', 'Paid'])->sum('amount');
        $total_out = $db::table('transaksi')->where(function($q) use ($auth) { $q->where('username', $auth->email)->orWhere('username', $auth->name); })->whereIn('status', ['success', 'sukses', 'Success', 'Lunas'])->sum('harga');
        $h_depo = $db::table('deposits')->where('user_id', $auth->id)->select('amount as amt', 'metode as title', 'status', 'created_at', $db::raw("'in' as type"))->orderBy('created_at', 'desc')->limit(5)->get();
        $h_trans = $db::table('transaksi')->where(function($q) use ($auth) { $q->where('username', $auth->email)->orWhere('username', $auth->name);
})->select('harga as amt', 'kode_layanan as title', 'status', 'created_at', $db::raw("'out' as type"))->orderBy('created_at', 'desc')->limit(10)->get();
        return inertia('Statistik', ['saldo_user' => (float) ($auth->saldo ?? 0), 'pemasukan' => (float) $total_in, 'pengeluaran' => (float) $total_out, 'riwayat' => $h_depo->concat($h_trans)->sortByDesc('created_at')->values()->take(15)]);
    })->name('statistik');
    // Anti Maling Session & H2H Webhook Setting
    Route::middleware([\App\Http\Middleware\AntiMalingSession::class])->group(function () {
