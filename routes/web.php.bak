        Route::post('/profile/update-h2h', function (\Illuminate\Http\Request $request) {
            $user = auth()->user();
            if ($request->action == 'generate') { $user->api_key = 'MS-' . strtoupper(\Illuminate\Support\Str::random(30)); }
            elseif ($request->action == 'generate_secret') { $user->payment_secret = 'SK-' . strtoupper(\Illuminate\Support\Str::random(32)); }
            else { $request->validate(['webhook_url' => 'nullable|url|max:255', 'payment_webhook' => 'nullable|url|max:255', 'ip_whitelist' => 'nullable|string|max:255']); $user->webhook_url = $request->webhook_url; $user->payment_webhook = $request->payment_webhook; $user->payment_secret = $request->payment_secret; $user->ip_whitelist = $request->ip_whitelist ? preg_replace('/\s+/', '', $request->ip_whitelist) : null; }
            $user->save(); return response()->json(['status' => true, 'message' => 'H2H Berhasil Disinkronkan!']);
        });
        Route::post('/user/test-webhook', function (\Illuminate\Http\Request $request) {
            $user = auth()->user(); $targetUrl = $request->input('custom_url') ?: ($user ? $user->webhook_url : null); if (empty($targetUrl)) return response()->json(['success' => false, 'message' => 'Masukkan URL!']);
            $statusReq = $request->input('status', 'Sukses'); $ref_id = 'TEST-WEBHOOK-' . time(); $sn = $statusReq === 'Sukses' ? 'SN-TEST-123' : '';
            try { $response = \Illuminate\Support\Facades\Http::timeout(10)->withoutVerifying()->post($targetUrl, ['status' => $statusReq, 'trx_id'
=> $ref_id, 'ref_id' => $ref_id, 'kode_produk' => 'TEST_PRODUK', 'tujuan'
=> '081234567890', 'sn' => $sn, 'message' => 'Transaksi '.$statusReq, 'signature' => md5(($user ? $user->api_key : 'APIKEY') . $ref_id)]); return response()->json(['success' => true, 'message' => 'Terkirim!', 'http_code' => $response->status(), 'response_body' => substr($response->body(), 0, 200)]); } catch (\Exception $e) { return response()->json(['success' => false, 'message' => 'Gagal: ' . $e->getMessage()]); }
        });
    });
});
