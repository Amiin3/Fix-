class BotWaController extends Controller
{
    protected $botKey = 'MILA_SEC_v9B4xK8mP2qL7jW5nC3zR1hT6fD0yX5g';
    
    private function getPrioritas($kode) {
        $prioMap = ['CFMX'=>0, 'XLA89'=>1, 'XLA14'=>2, 'XLA32'=>3, 'XLA39'=>4, 'XLA51'=>5, 'XLA65'=>6];
        return $prioMap[strtoupper($kode)] ?? 99;
    }
    
    private function getDesc($p) {
        $desc = $p->deskripsi ?? $p->catatan ?? '';
        if (empty($desc)) return '';
        
        $cleanDesc = trim(strip_tags(str_replace(['<br>', '<br/>', '<br />'], "\n", $desc)));
        $lines = explode("\n", $cleanDesc);
        $finalLines = [];
        
        foreach ($lines as $line) {
            $tLine = trim($line); if (empty($tLine)) continue;
            if (preg_match('/(Bisa ke XL|Resmi|Bergaransi|tanggung jawab|myRewerd|PRIORITAS|otomatis ke kick|Kesalahan nomor)/i', $tLine)) continue;
            
            if (strpos($tLine, '|') !== false) {
                $areas = explode('|', $tLine);
                foreach($areas as $area) {
                    $cleanArea = trim(str_replace([':', '-'], '=', $area));
                    if(!empty($cleanArea)) $finalLines[] = "▪️ " . $cleanArea;
                }
            } else {
                $cleanLine = trim(str_replace([':', '-'], '=', $tLine));
                if (stripos($cleanLine, 'Global') !== false) {
                    $finalLines[] = "🌐 " . $cleanLine;
                } else {
                    $finalLines[] = "▪️ " . $cleanLine;
                }
            }
        }
        
        if (empty($finalLines)) return '';
        return "\n  └ 📝 *Detail Kuota:*\n      " . implode("\n      ", array_slice($finalLines, 0, 15));
    }
    
    private function generateQrisCrc($str) {
        $crc = 0xFFFF;
        for ($i = 0; $i < strlen($str); $i++) {
            $crc ^= (ord($str[$i]) << 8);
            for ($j = 0; $j < 8; $j++) {
                if ($crc & 0x8000) { $crc = ($crc << 1) ^ 0x1021; } else { $crc = $crc << 1; }
            }
        }
        $crc &= 0xFFFF;
        return strtoupper(str_pad(dechex($crc), 4, '0', STR_PAD_LEFT));
    }
    
    private function makeDynamicQris($staticQris, $amount) {
        $qris = substr($staticQris, 0, -4);
        $qris = str_replace('010211', '010212', $qris);
        $amtStr = (string)$amount;
        $amtLen = str_pad(strlen($amtStr), 2, '0', STR_PAD_LEFT);
        $tag54 = "54" . $amtLen . $amtStr;
        if (strpos($qris, '5802ID') !== false) { $qris = str_replace('5802ID', $tag54 . '5802ID', $qris); } else { $qris .= $tag54; }
        return $qris . $this->generateQrisCrc($qris);
    }
    
    public function handle(Request $request)
    {

            // --- REAL AI GEMINI & REGISTRASI FIX ---
            // 1. DETEKSI PARAMETER REQUEST SECARA AGRESIF (Mendukung Semua Vendor Gateway WA)
            $pesanAsli = request('pesan') ?? request('message') ?? request('text') ?? request('msg') ?? request('data') ?? '';
            $no_wa = request('nomor') ?? request('sender') ?? request('from') ?? request('phone') ?? request('whatsapp') ?? '';
            
            // Ambil fallback jika variabel dilewatkan via parameter fungsi $request Laravel
            if (empty($pesanAsli) && isset($request)) {
                $pesanAsli = $request->pesan ?? $request->message ?? $request->text ?? $request->msg ?? '';
            }
            if (empty($no_wa) && isset($request)) {
                $no_wa = $request->nomor ?? $request->sender ?? $request->from ?? $request->phone ?? $request->whatsapp ?? '';
            }

            $pesanBersih = trim($pesanAsli);
            $no_wa = preg_replace('/[^0-9]/', '', str_replace('@c.us', '', $no_wa));

            if ($pesanBersih !== '' && $no_wa !== '') {
                $parts = explode(' ', $pesanBersih);
                $cmdRawAi = strtolower($parts[0] ?? '');
                $isDotAi = (str_starts_with($pesanBersih, '.'));
                $cmdAi = ltrim($cmdRawAi, '.');

                // RESPONDER ENGINE UNIVERSAL (Mengirimkan payload JSON terlengkap + teks murni secara simultan)
                $sendResponse = function($msg) use ($request) {
                    if (request()->wantsJson() || request()->is('api/*') || (isset($request) && method_exists($request, 'expectsJson') && $request->expectsJson())) {
                        return response()->json([
                            'status' => true,
                            'message' => $msg,
                            'text' => $msg,
                            'reply' => $msg,
                            'data' => ['reply' => $msg, 'message' => $msg, 'text' => $msg]
                        ]);
                    }
                    return response($msg, 200)->header('Content-Type', 'text/plain');
                };

                // VALIDASI DATABASE MITRA (Mendukung multispesifikasi nama kolom lokal)
                $user = \Illuminate\Support\Facades\DB::table('users')
                    ->where('whatsapp', $no_wa)
                    ->orWhere('phone', $no_wa)
                    ->orWhere('telepon', $no_wa)
                    ->first();

                // ENGINE PINTAR AI GEMINI
                $callGemini = function($prompt) {
                    $key = env('GEMINI_API_KEY');
                    if (empty($key)) return "⚠️ *SYSTEM ERROR:* API Key Gemini belum diisi di file .env!";
                    try {
                        $res = \Illuminate\Support\Facades\Http::timeout(12)->post("https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=" . $key, [
                            'contents' => [['parts' => [['text' => $prompt]]]]
                        ]);
                        return $res->json()['candidates'][0]['content']['parts'][0]['text'] ?? null;
                    } catch (\Exception $e) { 
                        return null; 
                    }
                };

                // ==========================================
                // BLOK 1: FITUR REGISTRASI (USER BELUM DAFTAR)
                // ==========================================
                if (!$user) {
                    if ($cmdAi === 'daftar' || $cmdAi === 'register') {
                        if (count($parts) < 3) {
                            return $sendResponse("Halo Kak! 👋\nFormat pendaftaran belum lengkap.\n\nSilakan ketik:\n`.daftar [Email_Aktif] [Nama_Toko]`\n\n💡 *Contoh:* \n`.daftar milastore@gmail.com Mila Cell`");
                        }
                        
                        $emailReg = $parts[1];
                        if (!filter_var($emailReg, FILTER_VALIDATE_EMAIL)) {
                            return $sendResponse("❌ *Pendaftaran Gagal:* Alamat email tidak valid!");
                        }
                        if (\Illuminate\Support\Facades\DB::table('users')->where('email', $emailReg)->first()) {
                            return $sendResponse("❌ *Pendaftaran Gagal:* Email ini sudah terdaftar!");
                        }

                        $namaTokoReg = implode(' ', array_slice($parts, 2));
                        $otpCode = mt_rand(100000, 999999);
                        $defaultPassword = 'Mila' . mt_rand(1000, 9999);

                        try {
                            \Illuminate\Support\Facades\DB::table('users')->insert([
                                'name' => $namaTokoReg, 'email' => $emailReg, 'whatsapp' => $no_wa, 'phone' => $no_wa,
                                'password' => \Illuminate\Support\Facades\Hash::make($defaultPassword), 'level' => 'Member',
                                'saldo' => 0, 'status' => 'pending', 'otp_code' => $otpCode, 'api_key' => \Illuminate\Support\Str::random(30),
                                'created_at' => date('Y-m-d H:i:s'), 'updated_at' => date('Y-m-d H:i:s')
                            ]);
                            return $sendResponse("🎉 *PENDAFTARAN SUKSES!*\n\nData Anda telah berhasil disimpan.\n\n🔑 *KODE OTP ANDA:* `$otpCode`\n\nSilakan verifikasi akun Anda dengan mengetik:\n`.verifikasi $otpCode $defaultPassword`");
                        } catch (\Exception $e) {
                            return $sendResponse("❌ *DATABASE ERROR:* Hubungi Admin Utama.");
                        }
                    }
                    
                    // Respon AI Otomatis untuk Mengajak Pendaftaran Akun jika nomor baru menyapa
                    $aiResp = $callGemini("Kamu adalah CS Virtual resmi MilaStore (Sistem Agen Top Up Game & PPOB H2H). Ada nomor baru belum terdaftar mengirim pesan kasual: '$pesanAsli'. Jawab dengan sangat ramah, santun, super singkat, lalu arahkan dia untuk mendaftar menggunakan format wajib bertanda titik: '.daftar email nama_toko'.");
                    if ($aiResp) {
                        return $sendResponse("🤖 *Mila AI - MILASTORE*\n\n" . trim($aiResp));
                    }
                    return $sendResponse("Halo Kak! 👋\nNomor Anda belum terdaftar di MilaStore. Yuk join sekarang!\n\nKetik format pendaftaran:\n`.daftar email_kakak@gmail.com Nama Toko`");
                }

                // ==========================================
                // BLOK 2: VERIFIKASI OTP (USER STATUS PENDING)
                // ==========================================
                if ($user->status === 'pending') {
                    if ($cmdAi === 'verifikasi' && isset($parts[1]) && $parts[1] == $user->otp_code) {
                        $passWeb = $parts[2] ?? '123456';
                        \Illuminate\Support\Facades\DB::table('users')->where('id', $user->id)->update([
                            'status' => 'aktif', 'otp_code' => null, 'wa_verified_at' => date('Y-m-d H:i:s')
                        ]);
                        
                        $msgSukses = "🎉 *VERIFIKASI AKUN SUKSES!* 🎉\nSelamat datang di MILASTORE, *{$user->name}*!\n\n";
                        $msgSukses .= "Akun Anda saat ini telah aktif dan sinkron ke Web Server.\n\n";
                        $msgSukses .= "🌐 *Link Login Web:* https://milastore.cloud/login\n";
                        $msgSukses .= "📧 *Email/ID:* {$user->email}\n";
                        $msgSukses .= "🔑 *Password Web:* `$passWeb`\n\n";
                        $msgSukses .= "_Silakan login ke web untuk melengkapi profile Anda._\n\n";
                        $msgSukses .= "Ketik *.menu* pada WhatsApp ini untuk melihat katalog produk h2h! 🚀";
                        return $sendResponse($msgSukses);
                    }
                    return $sendResponse("⚠️ *AKUN BELUM AKTIF*\n\nHarap lakukan verifikasi OTP terlebih dahulu.\nKetik: `.verifikasi {$user->otp_code}`");
                }

                // ==========================================
                // BLOK 3: ASISTEN CHAT AI (USER SUDAH AKTIF)
                // ==========================================
                $sysCmds = ['depo', 'deposit', 'order', 'beli', 'batal', 'menu', 'ping', 'help', 'saldo', 'cek', 'tagihan'];
                
                // Cek jika pengguna chat biasa atau lupa memberi tanda titik pada perintah bawaan web
                if (!in_array($cmdAi, $sysCmds) || (in_array($cmdAi, $sysCmds) && !$isDotAi)) {
                    $prompt = "Kamu Mila AI, asisten resmi MilaStore (Aplikasi PPOB & Agen Kuota). Pengguna terdaftar bernama '{$user->name}' mengirim pesan: '$pesanAsli'. Jawab ramah, padat, langsung ke inti. Jika dia bertanya cara transaksi, ingatkan aturan format wajib pakai titik: \n- Topup Saldo: .depo nominal\n- Beli Produk: .order kode_produk tujuan\n- Cek Katalog: .menu\nIngatkan selalu memakai tanda titik (.) di awal perintah.";
                    $aiResp = $callGemini($prompt);
                    
                    if ($aiResp) {
                        return $sendResponse("🤖 *Mila AI - MILASTORE*\n\n" . trim($aiResp));
                    }
                }
            }
            // --- END REAL AI ---
            
            
        try {
            date_default_timezone_set('Asia/Jakarta');
            if ($request->header('X-API-KEY') !== $this->botKey) { return response()->json(['status' => false, 'message' => '❌   Akses Ditolak!']); }
            
            $command = $request->command;
            $raw_wa = $request->no_wa;
            $no_wa = preg_replace("/[^0-9]/", "", explode("@", $raw_wa)[0]);
            
            if (empty($no_wa) || strlen($no_wa) < 9) return response()->json(["status" => false, "message" => "❌  Nomor pengirim tidak valid!"]);
            $indo_num = (substr($no_wa, 0, 2) == "62") ? "0" . substr($no_wa, 2) : $no_wa;
            $user = DB::table('users')->where('whatsapp', $no_wa)->orWhere('phone', $no_wa)->orWhere('phone', $indo_num)->first();

            

            
            

            

            

            

            

            

            
            
            if ($command === 'auto_otp' || $command === 'login') {
                $otp_input = trim($request->otp ?? '');
                if ($command === 'auto_otp') {
                    $userV = DB::table('users')->where('otp_code', $otp_input)->first();
                    if (!$userV) return response()->json(['status' => false, 'message' => "❌   *KODE OTP SALAH/DITOLAK!*\nSistem mendeteksi aktivitas mencurigakan atau kode salah."]);
                    DB::table('users')->where('id', $userV->id)->update(['whatsapp' => $no_wa, 'otp_code' => null]);
